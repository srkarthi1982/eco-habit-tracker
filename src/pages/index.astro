---
import { AvButton, AvContainer } from "@ansiversa/components";
import AppShell from "../layouts/AppShell.astro";
---

<AppShell title="Habit Tracker · Ansiversa" description="Build consistency with calm daily habit tracking.">
  <section class="border-b border-slate-800 bg-slate-950">
    <AvContainer size="narrow" className="py-20 text-center">
      <p class="mb-4 text-xs uppercase tracking-[0.24em] text-emerald-400">Ansiversa Mini App · Habit Tracker</p>
      <h1 class="mx-auto max-w-3xl text-4xl font-semibold text-slate-100 sm:text-5xl">
        Build better routines with a clean, focused habit workspace.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-base text-slate-300">
        Create your personal habits, check in daily, and keep progress visible without clutter. Habit Tracker is designed
        for consistency, not complexity.
      </p>
      <div class="mt-8 flex justify-center">
        <AvButton href="/app">Open your habit workspace</AvButton>
      </div>
    </AvContainer>
  </section>

  <section class="bg-slate-950">
    <AvContainer size="narrow" className="grid gap-4 py-14 sm:grid-cols-3">
      <article class="rounded-xl border border-slate-800 bg-slate-900/60 p-5">
        <h2 class="text-sm font-semibold text-slate-100">Track meaningful habits</h2>
        <p class="mt-2 text-sm text-slate-300">Keep health, learning, focus, and personal goals in one simple list.</p>
      </article>
      <article class="rounded-xl border border-slate-800 bg-slate-900/60 p-5">
        <h2 class="text-sm font-semibold text-slate-100">Log progress quickly</h2>
        <p class="mt-2 text-sm text-slate-300">One-click check-ins and tidy notes make daily use effortless.</p>
      </article>
      <article class="rounded-xl border border-slate-800 bg-slate-900/60 p-5">
        <h2 class="text-sm font-semibold text-slate-100">See calm momentum</h2>
        <p class="mt-2 text-sm text-slate-300">Recent history and lightweight summaries keep you oriented.</p>
      </article>
    </AvContainer>
  </section>
</AppShell>
