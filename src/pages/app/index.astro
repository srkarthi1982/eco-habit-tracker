---
import AppShell from "../../layouts/AppShell.astro";
import AvMiniAppBar from "../../components/AvMiniAppBar.astro";
import { listHabitsForUser } from "../../actions";

const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect("/");
}

const data = await listHabitsForUser(user.id, true);
const bootstrapPayload = JSON.stringify({ habits: data.items, summary: data.summary, tab: "overview" });
---

<AppShell title="Habit Tracker Workspace" description="Manage habits and daily progress.">
  <AvMiniAppBar title="Habit Tracker" subtitle="Your personal consistency workspace" />

  <main
    class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6"
    x-data
    x-init={`$store.habitTracker.bootstrap(${bootstrapPayload})`}
  >
    <div class="mb-4" x-show="$store.habitTracker.flash" x-transition>
      <p
        class="rounded-md border px-4 py-3 text-sm"
        :class="$store.habitTracker.flash?.type === 'success' ? 'border-emerald-600/30 bg-emerald-950/30 text-emerald-200' : 'border-red-500/40 bg-red-950/20 text-red-200'"
        x-text="$store.habitTracker.flash?.message"
      ></p>
    </div>

    <section class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
      <article class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
        <p class="text-xs text-slate-400">Total Habits</p>
        <p class="mt-1 text-2xl font-semibold text-slate-100" x-text="$store.habitTracker.summary.totalHabits"></p>
      </article>
      <article class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
        <p class="text-xs text-slate-400">Active</p>
        <p class="mt-1 text-2xl font-semibold text-slate-100" x-text="$store.habitTracker.summary.activeHabits"></p>
      </article>
      <article class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
        <p class="text-xs text-slate-400">Archived</p>
        <p class="mt-1 text-2xl font-semibold text-slate-100" x-text="$store.habitTracker.summary.archivedHabits"></p>
      </article>
      <article class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
        <p class="text-xs text-slate-400">Recent logs (7d)</p>
        <p class="mt-1 text-2xl font-semibold text-slate-100" x-text="$store.habitTracker.summary.recentLogs"></p>
      </article>
      <article class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
        <p class="text-xs text-slate-400">Completed today</p>
        <p class="mt-1 text-2xl font-semibold text-slate-100" x-text="$store.habitTracker.summary.completionsToday"></p>
      </article>
    </section>

    <section class="mt-6 rounded-xl border border-slate-800 bg-slate-900/50 p-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="inline-flex rounded-md border border-slate-700 p-1 text-sm">
          <button class="rounded px-3 py-1" :class="$store.habitTracker.activeTab === 'overview' ? 'bg-slate-100 text-slate-900' : 'text-slate-300'" @click="$store.habitTracker.setTab('overview')">Overview</button>
          <button class="rounded px-3 py-1" :class="$store.habitTracker.activeTab === 'habits' ? 'bg-slate-100 text-slate-900' : 'text-slate-300'" @click="$store.habitTracker.setTab('habits')">Habits</button>
          <button class="rounded px-3 py-1" :class="$store.habitTracker.activeTab === 'archived' ? 'bg-slate-100 text-slate-900' : 'text-slate-300'" @click="$store.habitTracker.setTab('archived')">Archived</button>
        </div>
        <button class="rounded-md bg-emerald-500 px-4 py-2 text-sm font-semibold text-slate-950" @click="$store.habitTracker.modal.create = true">Create habit</button>
      </div>

      <div class="mt-5 space-y-3" x-show="$store.habitTracker.activeTab === 'overview' || $store.habitTracker.activeTab === 'habits'">
        <template x-for="habit in $store.habitTracker.habits.filter((h) => h.status === 'active')" :key="habit.id">
          <article class="rounded-lg border border-slate-800 bg-slate-950/50 p-4">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <a class="text-base font-semibold text-slate-100 hover:text-emerald-300" :href="`/app/habits/${habit.id}`" x-text="habit.title"></a>
                <p class="mt-1 text-xs text-slate-400" x-text="`${habit.frequencyType} · target ${habit.targetPerPeriod}`"></p>
              </div>
              <div class="flex gap-2">
                <button class="rounded border border-slate-700 px-3 py-1 text-xs text-slate-200" @click="await $store.habitTracker.archiveHabit(habit.id)">Archive</button>
                <a class="rounded border border-slate-700 px-3 py-1 text-xs text-slate-200" :href="`/app/habits/${habit.id}`">Details</a>
              </div>
            </div>
          </article>
        </template>
        <p class="rounded-lg border border-dashed border-slate-700 p-8 text-center text-sm text-slate-400" x-show="$store.habitTracker.habits.filter((h) => h.status === 'active').length === 0">No active habits yet. Start by creating your first habit.</p>
      </div>

      <div class="mt-5 space-y-3" x-show="$store.habitTracker.activeTab === 'archived'">
        <template x-for="habit in $store.habitTracker.habits.filter((h) => h.status === 'archived')" :key="habit.id">
          <article class="rounded-lg border border-slate-800 bg-slate-950/40 p-4 opacity-90">
            <div class="flex items-center justify-between gap-3">
              <div>
                <p class="text-sm font-medium text-slate-200" x-text="habit.title"></p>
                <p class="text-xs text-slate-500">Archived habit · history preserved</p>
              </div>
              <button class="rounded border border-slate-700 px-3 py-1 text-xs text-slate-200" @click="await $store.habitTracker.restoreHabit(habit.id)">Restore</button>
            </div>
          </article>
        </template>
        <p class="rounded-lg border border-dashed border-slate-700 p-8 text-center text-sm text-slate-400" x-show="$store.habitTracker.habits.filter((h) => h.status === 'archived').length === 0">No archived habits.</p>
      </div>
    </section>

    <div x-show="$store.habitTracker.modal.create" class="fixed inset-0 z-50 bg-slate-950/70 p-4">
      <div class="mx-auto mt-16 w-full max-w-lg rounded-xl border border-slate-800 bg-slate-900 p-5">
        <div class="mb-4 flex items-center justify-between">
          <h3 class="text-lg font-semibold text-slate-100">Create habit</h3>
          <button class="text-slate-400" @click="$store.habitTracker.modal.create = false">✕</button>
        </div>
        <form
          class="space-y-3"
          @submit.prevent="await $store.habitTracker.createHabit(new FormData($event.target))"
        >
          <input name="title" required placeholder="Habit name" class="w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" />
          <select name="category" class="w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100">
            <option value="">Category (optional)</option>
            <option value="health">Health</option><option value="learning">Learning</option><option value="focus">Focus</option><option value="fitness">Fitness</option><option value="finance">Finance</option><option value="personal">Personal</option><option value="custom">Custom</option>
          </select>
          <div class="grid grid-cols-2 gap-2">
            <select name="frequencyType" class="rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100"><option value="daily">Daily</option><option value="weekly">Weekly</option></select>
            <input type="number" name="targetPerPeriod" min="1" value="1" class="rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" />
          </div>
          <textarea name="notes" placeholder="Notes (optional)" rows="3" class="w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100"></textarea>
          <button class="w-full rounded-md bg-emerald-500 px-4 py-2 font-semibold text-slate-950" :disabled="$store.habitTracker.submitting">Save habit</button>
        </form>
      </div>
    </div>
  </main>
</AppShell>
