---
import { HABIT_TRACKER_APP } from "../lib/app-meta";

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="border-b border-slate-800 bg-slate-950/90 backdrop-blur" data-app-id={HABIT_TRACKER_APP.id}>
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <div class="flex items-center gap-3">
      <img src={HABIT_TRACKER_APP.logoPath} alt="Habit Tracker" class="h-7 w-7 rounded" />
      <div>
        <a href="/app" class="text-lg font-semibold text-slate-100">{title}</a>
        {subtitle && <p class="text-xs text-slate-400">{subtitle}</p>}
      </div>
    </div>
    <a
      href={Astro.locals.rootAppUrl ?? "https://ansiversa.com"}
      class="rounded-md border border-slate-700 px-3 py-1.5 text-sm text-slate-200 hover:border-slate-500"
    >
      Ansiversa Dashboard
    </a>
  </div>
</header>
